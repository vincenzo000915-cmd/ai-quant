# Flask
SECRET_KEY=change-this-to-random-secret

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=quant
DB_USER=quant
DB_PASS=quant_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Exchange (Binance testnet)
EXCHANGE_NAME=binance
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_secret_here
EXCHANGE_TESTNET=true

# Trading
DEFAULT_SYMBOL=BTC/USDT
DEFAULT_TIMEFRAME=4h

# Risk control
MAX_DAILY_LOSS=10
MAX_POSITIONS=3
MAX_POSITION_SIZE=20
STOP_LOSS_PERCENT=5
TAKE_PROFIT_PERCENT=15

# Telegram notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Phase 4 LLM translator (Anthropic API)
ANTHROPIC_API_KEY=
LLM_TRANSLATOR_MODEL=claude-sonnet-4-6
